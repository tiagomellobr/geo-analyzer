# ─── Servidor ────────────────────────────────────────────────────────────────
BIND=0.0.0.0:3000
RUST_LOG=geo_analyzer=info,tower_http=info

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=sqlite://geo_analyzer.db

# ─── Sessão ───────────────────────────────────────────────────────────────────
# Em produção, defina como true (exige HTTPS)
SESSION_SECURE=false

# ─── Ollama (LLM local) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:1b
OLLAMA_TIMEOUT_SECS=120

# ─── E-mail (recuperação de senha) ───────────────────────────────────────────
# Preencha com as credenciais do seu provedor SMTP (ex: SendGrid, SES, Gmail SMTP)
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USER=usuario@exemplo.com
SMTP_PASS=sua_senha_aqui
SMTP_FROM=noreply@seudominio.com
APP_BASE_URL=https://seudominio.com
